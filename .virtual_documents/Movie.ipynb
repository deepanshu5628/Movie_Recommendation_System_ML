# keep only keywords or we can say tags
def keywords_process(text):
    keywords=[]
    arr=json.loads(text)
    for item in arr:
        keywords.append(item["name"].replace(" ",""))
    return keywords

merged_df["keywords"]=merged_df["keywords"].apply(keywords_process)

# keep only top 3 actory names
def cast_process(text):
    final_cast=[]
    arr=json.loads(text)
    count=1
    for item in arr:
        if count <=3:
            name=item["name"]
            name_without_space=name.replace(" ","")
            final_cast.append(name_without_space)
            count+=1
        else:
            break
    return final_cast
merged_df["cast"]=merged_df["cast"].apply(cast_process)

# keep only the director name in the list 
def crew_process(text):
    director_name=[]
    arr=json.loads(text)
    for item in arr:
        if item["job"]=="Director":
            director_name.append(item["name"].replace(" ",""))
            break
    return director_name

merged_df["crew"]=merged_df["crew"].apply(crew_process)





merged_df["summary"]=merged_df["keywords"]+merged_df["cast"]+merged_df["crew"]
def convert_list_to_str(given_list):
    return " ".join(given_list)

merged_df["summary"]=merged_df["summary"].apply(convert_list_to_str)
merged_df["overview"]=merged_df["overview"]+" "+merged_df["summary"]
merged_df=merged_df[["id","title","overview"]]





# convert all the letters in the lower case 
def convert_lowerCase(text):
    lower_text=str.lower(text)
    return lower_text

# remvoe the !@#$%^&*() from the text
def remove_punctuations(text):
    final_text=re.sub(r"[^A-Za-z0-9\s]","",text)
    return final_text

# remove stop words
def remove_stopwords(text):
    final_str=[]
    stopWords=stopwords.words("english")
    tokens=word_tokenize(text)
    for token in tokens:
        if token in stopWords:
            continue
        else:
            final_str.append(token)
    return " ".join(final_str)        

    
#perfrom stemming on the text
ps=PorterStemmer()
def do_stemming(text):
    stemmed_words=[]
    tokens=word_tokenize(text)
    for token in tokens:
        stemmed_words.append(ps.stem(token))
    return " ".join(stemmed_words)

merged_df["overview"]=merged_df["overview"].apply(convert_lowerCase)
merged_df["overview"]=merged_df["overview"].apply(remove_punctuations)
merged_df["overview"]=merged_df["overview"].apply(remove_stopwords)
merged_df["overview"]=merged_df["overview"].apply(do_stemming)





vectorization =TfidfVectorizer(max_features=5000)
bow=CountVectorizer(max_features=5000)
vectors=vectorization.fit_transform(merged_df["overview"])
# vectors=bow.fit_transform(merged_df["overview"])





x=cosine_similarity(vectors)





def main_function(movie_name):
    # find the index of movie so that we can find it logt's vector
    movie_index= merged_df[merged_df["title"]==movie_name].index[0]
    logits=x[movie_index] # this logit is of the movie. it has it similarity score with all of the other movies. 
    # we just have to find the moveies which has the highest similarity score 
    arr_dict=list(enumerate(logits)) #with arr_dict we have preserved the index as well as there score .now we can sort this 
    # but  we have to sort in to the 2nd column of similariry score 
    movie_with_highest_similarity=sorted(arr_dict,reverse=True,key=lambda x:x[1])
    top_5=movie_with_highest_similarity[0:6]
    # now we have index of top 3 movies
    movie_info=print_name(top_5)
    return movie_info

def print_name(top5mov):
    movie_info=[]
    for item in top5mov:
        movie_info.append(merged_df.iloc[item[0]])
        print(merged_df.iloc[item[0]]["title"]) #here we have acccessed the index of the dataframe
    return movie_info





main_function("Spider-Man 3")





pickle.dump(merged_df,open("./Pickle/movies.pkl","wb"))
pickle.dump(main_function,open("./Pickle/recommend.pkl","wb"))


